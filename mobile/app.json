{
  "expo": {
    "name": "FieldSync",
    "slug": "fieldsync",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1E3A8A"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1E3A8A"
      },
      "package": "com.fieldsync.app"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "scheme": "fieldsync",
    "extra": {
      "apiUrl": "https://fieldsync-api.onrender.com/api"
    }
  }
}
